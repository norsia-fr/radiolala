{
  "name": "radiolala",
  "description": "Lecteur de webradios minimaliste, personnalisable et respectueux de la vie privée (PWA).",
  "version": "2.0.0",
  "private": false,
  "license": "GPL-3.0-or-later",
  "author": "Norsia",
  "keywords": [
    "radio",
    "player",
    "vue",
    "vue3",
    "pinia",
    "pwa"
  ],
  "homepage": "https://norsia-fr.github.io/radiolala",
  "repository": {
    "type": "git",
    "url": "https://github.com/norsia-fr/radiolala.git"
  },
  "bugs": {
    "url": "https://github.com/norsia-fr/radiolala/issues"
  },
  "scripts": {
    "serve": "vue-cli-service serve",
    "prebuild": "node scripts/sync-manifest.js",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@vueuse/core": "^14.3.0",
    "animate.css": "^4.1.1",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "core-js": "^3.8.3",
    "marked": "^18.0.3",
    "pinia": "^3.0.1",
    "vue": "^3.2.13",
    "vue-draggable-next": "^2.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    "rules": {
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }]
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
